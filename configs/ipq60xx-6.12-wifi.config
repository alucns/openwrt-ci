CONFIG_KERNEL_SECURITY_SELINUX=n
CONFIG_KERNEL_SECURITY_APPARMOR=n
CONFIG_KERNEL_LSM_MMAP_MIN_ADDR=32768
CONFIG_KERNEL_FS_XFS=n
CONFIG_KERNEL_FS_BTRFS=n

# 内存管理优化
