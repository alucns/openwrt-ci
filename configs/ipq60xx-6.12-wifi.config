CONFIG_KERNEL_PAGE_POISONING=n
CONFIG_KERNEL_PAGE_TABLE_ISOLATION=n
CONFIG_KERNEL_SLAB_FREELIST_RANDOM=n
CONFIG_KERNEL_SLAB_FREELIST_HARDENED=n

# TCP网络优化 - 已通过 kmod-tcp-bbr 实现，无需在此处设置内核选项
# 以下全部删除：CONFIG_TCP_CONG_*, CONFIG_KERNEL_TCP_*, CONFIG_KERNEL_DEFAULT_TCP_CONG
# 同时删除 CONFIG_KERNEL_IP_MULTIPLE_TABLES 和 CONFIG_KERNEL_IP_ADVANCED_ROUTER（包依赖自动处理）

# 高通NSS驱动优化
CONFIG_NSS_DRV_BRIDGE_ENABLE=y
CONFIG_NSS_DRV_VLAN_ENABLE=y

