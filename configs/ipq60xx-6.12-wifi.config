CONFIG_KERNEL_DEBUG_INFO_REDUCED=n
CONFIG_KERNEL_DEBUG_KERNEL=n
CONFIG_KERNEL_DEBUG_RODATA=n
CONFIG_KERNEL_SLUB_DEBUG=n
